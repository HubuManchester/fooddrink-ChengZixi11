<?xml version="1.0" encoding="utf-8" ?>

<!-- Hardware feature demonstration page -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo"
             BackgroundColor="{AppThemeBinding Light=#F6F0FF, Dark=#1F1B2E}">

    <ScrollView>

        <!-- Page background gradient -->
        <ScrollView.Background>

            <AppThemeBinding>

                <!-- Light mode background -->
                <AppThemeBinding.Light>

                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">

                        <GradientStop Color="#F6F0FF"
                                      Offset="0.0" />

                        <GradientStop Color="#F2EAFF"
                                      Offset="0.5" />

                        <GradientStop Color="#EEE4FF"
                                      Offset="1.0" />

                    </LinearGradientBrush>

                </AppThemeBinding.Light>

                <!-- Dark mode background -->
                <AppThemeBinding.Dark>

                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">

                        <GradientStop Color="#1F1B2E"
                                      Offset="0.0" />

                        <GradientStop Color="#2A243B"
                                      Offset="0.5" />

                        <GradientStop Color="#352D4A"
                                      Offset="1.0" />

                    </LinearGradientBrush>

                </AppThemeBinding.Dark>

            </AppThemeBinding>

        </ScrollView.Background>

        <!-- Main page layout -->
        <VerticalStackLayout Padding="22"
                             Spacing="16">

            <!-- Header information card -->
            <Border StrokeThickness="0"
                    Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A243B}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="6">

                    <!-- Page title -->
                    <Label Text="Mobile Hardware"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#F3EEFF}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <!-- Page description -->
                    <Label Text="Demonstrate camera, location, speech, vibration, and haptic feedback."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6D5D82, Dark=#D4CAE9}" />

                </VerticalStackLayout>

            </Border>

            <!-- Camera and photo capture card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D6C2FF, Dark=#5C4B7D}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A243B}"
                    Padding="16">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="14">

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">

                        <VerticalStackLayout Spacing="3">

                            <!-- Camera section title -->
                            <Label Text="Food Photo"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#8B6FB3, Dark=#E4DAFF}" />

                            <!-- Camera section description -->
                            <Label Text="Capture the colour and condition of the meal."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#6D5D82, Dark=#D4CAE9}" />

                        </VerticalStackLayout>

                        <!-- Open camera button -->
                        <Button Grid.Column="1"
                                Text="Photo"
                                BackgroundColor="#FFE9A8"
                                TextColor="#4B3B5A"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open the camera to capture a food image" />

                    </Grid>

                    <!-- Photo preview area -->
                    <Border StrokeThickness="1"
                            Stroke="{AppThemeBinding Light=#D6C2FF, Dark=#5C4B7D}"
                            BackgroundColor="{AppThemeBinding Light=#F7F1FF, Dark=#332B47}"
                            HeightRequest="220">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <!-- Captured image preview -->
                        <Image x:Name="FoodPhoto"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Captured food photo preview" />

                    </Border>

                </VerticalStackLayout>

            </Border>

            <!-- Location service card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D6C2FF, Dark=#5C4B7D}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2A243B}"
                    Padding="16">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="10">

                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">

                        <VerticalStackLayout Spacing="3">

                            <!-- Location section title -->
                            <Label Text="Meal Location"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#8B6FB3, Dark=#E4DAFF}" />

                            <!-- Location section description -->
                            <Label Text="Show country, city, region, and coordinates."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light=#6D5D82, Dark=#D4CAE9}" />

                        </VerticalStackLayout>

                        <!-- Get current location button -->
                        <Button Grid.Column="1"
                                Text="Locate"
                                BackgroundColor="#FFE9A8"
                                TextColor="#4B3B5A"
                                CornerRadius="14"
                                FontAttributes="Bold"
                                Clicked="OnGetLocationClicked"
                                SemanticProperties.Hint="Use location to record the meal place" />

                    </Grid>

                    <!-- Human-readable location -->
                    <Label x:Name="LocationLabel"
                           Grid.Row="1"
                           Text="Location has not been captured yet."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5F5172, Dark=#E6DEFF}" />

                    <!-- Latitude and longitude display -->
                    <Label x:Name="CoordinateLabel"
                           Grid.Row="2"
                           Text="Coordinates will appear here."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#9A8AB5, Dark=#CFC3EA}" />

                </Grid>

            </Border>

            <!-- Speech control buttons -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">

                <!-- Read help information aloud -->
                <Button Text="Read Help"
                        BackgroundColor="#FFE9A8"
                        TextColor="#4B3B5A"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        Clicked="OnReadHelpClicked"
                        SemanticProperties.Hint="Read the help text aloud" />

                <!-- Stop current speech -->
                <Button Grid.Column="1"
                        Text="Stop Speech"
                        BackgroundColor="{AppThemeBinding Light=#F7F1FF, Dark=#332B47}"
                        BorderColor="{AppThemeBinding Light=#D6C2FF, Dark=#5C4B7D}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#6D5D82, Dark=#E6DEFF}"
                        CornerRadius="14"
                        FontAttributes="Bold"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop current speech" />

            </Grid>

            <!-- Haptic feedback and vibration test button -->
            <Button Text="Haptic Feedback"
                    BackgroundColor="{AppThemeBinding Light=#F7F1FF, Dark=#332B47}"
                    BorderColor="{AppThemeBinding Light=#D6C2FF, Dark=#5C4B7D}"
                    BorderWidth="1"
                    TextColor="{AppThemeBinding Light=#6D5D82, Dark=#E6DEFF}"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    Clicked="OnFeedbackClicked"
                    SemanticProperties.Hint="Trigger vibration and haptic feedback" />

            <!-- Hardware status panel -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#D6C2FF, Dark=#5C4B7D}"
                    BackgroundColor="{AppThemeBinding Light=#FFF7D6, Dark=#4A3F1F}"
                    Padding="14">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="6">

                    <!-- Current hardware operation status -->
                    <Label x:Name="HardwareStatusLabel"
                           Text="Ready."
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#A06B00, Dark=#FFE39A}" />

                    <!-- Haptic feedback test counter -->
                    <Label x:Name="FeedbackCountLabel"
                           Text="Haptic feedback tests: 0"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light=#6D5D82, Dark=#D4CAE9}" />

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>