<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Record"
             BackgroundColor="{AppThemeBinding Light=#F8F4FF, Dark=#1E1A24}">

    <ScrollView>

        <VerticalStackLayout Padding="20"
                             Spacing="20">

            <!-- Banner -->
            <Grid HeightRequest="180">

                <Border StrokeThickness="0">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="30"/>
                    </Border.StrokeShape>

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,1">

                            <GradientStop Color="#D8C3FF"
                                          Offset="0"/>

                            <GradientStop Color="#E9DEFF"
                                          Offset="0.55"/>

                            <GradientStop Color="#FFE9A8"
                                          Offset="1"/>

                        </LinearGradientBrush>
                    </Border.Background>

                </Border>

                <VerticalStackLayout Padding="24"
                                     VerticalOptions="Center">

                    <Label Text="Create New Entry"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#4B3B5A"/>

                    <Label Text="Store meals, beverages and nutrition information in one place."
                           FontSize="15"
                           TextColor="#5F5172"/>

                </VerticalStackLayout>

            </Grid>

            <!-- Basic Details -->
            <Label Text="MEAL INFORMATION"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#8B6FB3"/>

            <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#31283C}"
                    Stroke="{AppThemeBinding Light=#D8C5FF, Dark=#4D405D}"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">

                    <!-- Name -->
                    <Entry x:Name="NameEntry"
                           Placeholder="Meal or drink name"
                           BackgroundColor="{AppThemeBinding Light=#F7F2FF, Dark=#3A3047}"
                           TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"
                           PlaceholderColor="#A494BF"/>

                    <!-- Category -->
                    <Picker x:Name="CategoryPicker"
                            Title="Choose category"
                            BackgroundColor="{AppThemeBinding Light=#F7F2FF, Dark=#3A3047}"
                            TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}">

                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Beverage</x:String>
                        </Picker.Items>

                    </Picker>

                    <!-- Description -->
                    <Editor x:Name="DescriptionEditor"
                            HeightRequest="120"
                            AutoSize="TextChanges"
                            BackgroundColor="{AppThemeBinding Light=#F7F2FF, Dark=#3A3047}"
                            TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"
                            Placeholder="Describe ingredients, flavour or preparation"/>

                </VerticalStackLayout>

            </Border>

            <!-- Nutrition Panel -->
            <Border BackgroundColor="{AppThemeBinding Light=#FFF8DA, Dark=#4B3B22}"
                    StrokeThickness="0"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">

                    <Label Text="NUTRITION VALUES"
                           FontAttributes="Bold"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#9A6800, Dark=#FFD978}"/>

                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="12"
                          RowSpacing="12">

                        <Entry x:Name="CaloriesEntry"
                               Placeholder="Calories"
                               Grid.Row="0"
                               Grid.Column="0"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#3A3047}"
                               TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"/>

                        <Entry x:Name="ProteinEntry"
                               Placeholder="Protein g"
                               Grid.Row="0"
                               Grid.Column="1"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#3A3047}"
                               TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"/>

                        <Entry x:Name="CarbsEntry"
                               Placeholder="Carbohydrates g"
                               Grid.Row="1"
                               Grid.Column="0"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#3A3047}"
                               TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"/>

                        <Entry x:Name="FatEntry"
                               Placeholder="Fat g"
                               Grid.Row="1"
                               Grid.Column="1"
                               Keyboard="Numeric"
                               BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#3A3047}"
                               TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"/>

                    </Grid>

                </VerticalStackLayout>

            </Border>

            <!-- Allergy Notes -->
            <Border BackgroundColor="{AppThemeBinding Light=#F7F2FF, Dark=#31283C}"
                    Stroke="{AppThemeBinding Light=#D8C5FF, Dark=#4D405D}"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">

                    <Label Text="DIETARY NOTES"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#8B6FB3, Dark=#D6BFFF}"/>

                    <Entry x:Name="AllergyEntry"
                           Placeholder="Allergy information or dietary restrictions"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#3A3047}"
                           TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"
                           PlaceholderColor="#A494BF"/>

                </VerticalStackLayout>

            </Border>

            <!-- Validation -->
            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light=#FFF4D6, Dark=#5A4722}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>

                <Label x:Name="ValidationLabel"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#A06B00, Dark=#FFD978}"/>

            </Border>

            <!-- Save Button -->
            <Button Text="Save Entry"
                    HeightRequest="62"
                    CornerRadius="28"
                    FontSize="18"
                    FontAttributes="Bold"
                    Clicked="OnSaveClicked"
                    BackgroundColor="{AppThemeBinding Light=#CDB4FF, Dark=#8B6CC7}"
                    TextColor="{AppThemeBinding Light=#4B3B5A, Dark=White}"
                    Margin="0,10,0,20"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>