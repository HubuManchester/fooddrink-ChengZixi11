<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Record"
             BackgroundColor="{AppThemeBinding Light=#F7F2FF, Dark=#1E1A24}">

    <ScrollView>

        <!-- 页面背景 -->
        <ScrollView.Background>
            <AppThemeBinding>

                <!-- Light -->
                <AppThemeBinding.Light>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">

                        <GradientStop Color="#F7F2FF"
                                      Offset="0.0" />

                        <GradientStop Color="#EEE4FF"
                                      Offset="0.55" />

                        <GradientStop Color="#FFF7D9"
                                      Offset="1.0" />

                    </LinearGradientBrush>
                </AppThemeBinding.Light>

                <!-- Dark -->
                <AppThemeBinding.Dark>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">

                        <GradientStop Color="#1E1A24"
                                      Offset="0.0" />

                        <GradientStop Color="#262031"
                                      Offset="0.5" />

                        <GradientStop Color="#2D2537"
                                      Offset="1.0" />

                    </LinearGradientBrush>
                </AppThemeBinding.Dark>

            </AppThemeBinding>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22"
                             Spacing="18">

            <!-- 顶部区域 -->
            <Border StrokeThickness="0"
                    Padding="22"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#31283C}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,4"
                            Radius="12"
                            Opacity="0.18" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="8">

                    <Label Text="Create Meal Entry"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#F3EFFF}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label Text="Save meal details, nutrition values, and personal notes in your food journal."
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#7A6A92, Dark=#CDBEE2}" />

                </VerticalStackLayout>

            </Border>

            <!-- Meal Details -->
            <Border Stroke="{AppThemeBinding Light=#D8C5FF, Dark=#4B3D5A}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#31283C}"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">

                    <Label Text="Meal Details"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#8B6FB3, Dark=#D6BFFF}" />

                    <!-- Name -->
                    <Border Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                            Padding="12,4">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Entry x:Name="NameEntry"
                               Placeholder="Meal or drink name"
                               TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                               PlaceholderColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                               BackgroundColor="Transparent"
                               SemanticProperties.Hint="Required food or drink name" />

                    </Border>

                    <!-- Category -->
                    <Border Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                            Padding="12,4">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Picker x:Name="CategoryPicker"
                                Title="Select category"
                                TitleColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                                TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                                BackgroundColor="Transparent"
                                SemanticProperties.Hint="Required category">

                            <Picker.Items>
                                <x:String>Breakfast</x:String>
                                <x:String>Lunch</x:String>
                                <x:String>Dinner</x:String>
                                <x:String>Snack</x:String>
                                <x:String>Beverage</x:String>
                            </Picker.Items>

                        </Picker>

                    </Border>

                    <!-- Description -->
                    <Border Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                            Padding="12">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Editor x:Name="DescriptionEditor"
                                Placeholder="Taste, ingredients, cooking style, or meal notes"
                                PlaceholderColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                                TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                                BackgroundColor="Transparent"
                                AutoSize="TextChanges"
                                HeightRequest="120"
                                SemanticProperties.Hint="Describe this meal" />

                    </Border>

                </VerticalStackLayout>

            </Border>

            <!-- Nutrition -->
            <Border Stroke="{AppThemeBinding Light=#D8C5FF, Dark=#4B3D5A}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#31283C}"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="16">

                    <Label Text="Nutrition Summary"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#78A26F, Dark=#B5E0A8}" />

                    <!-- Calories + Protein -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">

                        <Border Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                                Padding="12,4">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Entry x:Name="CaloriesEntry"
                                   Placeholder="Calories"
                                   Keyboard="Numeric"
                                   TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                                   BackgroundColor="Transparent"
                                   SemanticProperties.Hint="Required calories value" />

                        </Border>

                        <Border Grid.Column="1"
                                Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                                Padding="12,4">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Entry x:Name="ProteinEntry"
                                   Placeholder="Protein g"
                                   Keyboard="Numeric"
                                   TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                                   BackgroundColor="Transparent" />

                        </Border>

                    </Grid>

                    <!-- Carbs + Fat -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">

                        <Border Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                                Padding="12,4">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Entry x:Name="CarbsEntry"
                                   Placeholder="Carbohydrates g"
                                   Keyboard="Numeric"
                                   TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                                   BackgroundColor="Transparent" />

                        </Border>

                        <Border Grid.Column="1"
                                Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                                Padding="12,4">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>

                            <Entry x:Name="FatEntry"
                                   Placeholder="Fat g"
                                   Keyboard="Numeric"
                                   TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                                   PlaceholderColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                                   BackgroundColor="Transparent" />

                        </Border>

                    </Grid>

                    <!-- Allergy -->
                    <Border Stroke="{AppThemeBinding Light=#E4D8FF, Dark=#524364}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=#FAF7FF, Dark=#3A3047}"
                            Padding="12,4">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Entry x:Name="AllergyEntry"
                               Placeholder="Allergy or dietary notes"
                               TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                               PlaceholderColor="{AppThemeBinding Light=#9A8AB5, Dark=#B8A9CC}"
                               BackgroundColor="Transparent"
                               SemanticProperties.Hint="Dietary information" />

                    </Border>

                </VerticalStackLayout>

            </Border>

            <!-- Validation -->
            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFF4D6, Dark=#5A4722}"
                    Padding="14">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <Label x:Name="ValidationLabel"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#A06B00, Dark=#FFD978}" />

            </Border>

            <!-- Save Button -->
            <Button Text="Save Entry"
                    HeightRequest="58"
                    CornerRadius="20"
                    FontAttributes="Bold"
                    FontSize="18"
                    BackgroundColor="{AppThemeBinding Light=#D4BEFF, Dark=#8C6CC7}"
                    TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                    Clicked="OnSaveClicked"
                    SemanticProperties.Hint="Save this meal record" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>