<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite">

    <Grid RowDefinitions="Auto,*">

        <!-- 页面背景 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F6F0FF" Offset="0.0" />
                <GradientStop Color="#F2EAFF" Offset="0.5" />
                <GradientStop Color="#EEE4FF" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 顶部区域 -->
        <Grid Padding="20,18,20,18">

            <Border StrokeThickness="0"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <!-- 顶部卡片渐变 -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#CDB4FF" Offset="0.0" />
                        <GradientStop Color="#DCC6FF" Offset="0.5" />
                        <GradientStop Color="#EEE4FF" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,6"
                            Radius="15"
                            Opacity="0.25" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="12">

                    <!-- 标题 -->
                    <Label Text="NutriBite"
                           FontSize="31"
                           FontAttributes="Bold"
                           TextColor="#4B3B5A"
                           SemanticProperties.HeadingLevel="Level1" />

                    <!-- 描述 -->
                    <Label Grid.Row="1"
                           Text="Track nutrition, flavour, photos, and meal context in one place."
                           FontSize="15"
                           TextColor="#5F5172" />

                    <!-- 顶部标签 -->
                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="8"
                          Margin="0,3,0,0">

                        <Border BackgroundColor="#F7F1FF"
                                Stroke="#D6C2FF"
                                StrokeThickness="1"
                                Padding="10,7">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Label Text="Nutrition"
                                   TextColor="#5B4B73"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                        </Border>

                        <Border Grid.Column="1"
                                BackgroundColor="#F7F1FF"
                                Stroke="#D6C2FF"
                                StrokeThickness="1"
                                Padding="10,7">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Label Text="Photos"
                                   TextColor="#5B4B73"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                        </Border>

                        <Border Grid.Column="2"
                                BackgroundColor="#F7F1FF"
                                Stroke="#D6C2FF"
                                StrokeThickness="1"
                                Padding="10,7">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Label Text="Voice"
                                   TextColor="#5B4B73"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                        </Border>

                    </Grid>

                    <!-- 搜索框 -->
                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10"
                          Margin="0,6,0,0">

                        <Border StrokeThickness="1"
                                Stroke="#D6C2FF"
                                BackgroundColor="#FFFFFF"
                                Padding="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Search foods, drinks, categories, or tags"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       TextColor="#4B3B5A"
                                       PlaceholderColor="#9A8AB5"
                                       BackgroundColor="Transparent"
                                       SemanticProperties.Hint="Search the food and drink list" />
                        </Border>

                        <!-- Add 按钮 -->
                        <Button Grid.Column="1"
                                Text="Add"
                                BackgroundColor="#FFE9A8"
                                TextColor="#4B3B5A"
                                FontAttributes="Bold"
                                CornerRadius="14"
                                Clicked="OnAddClicked"
                                SemanticProperties.Hint="Add a new food or drink record" />

                    </Grid>

                </Grid>

            </Border>

        </Grid>

        <!-- 食物列表 -->
        <RefreshView Grid.Row="1"
                     x:Name="FoodRefreshView"
                     Refreshing="OnRefreshing">

            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="No matching food or drink records."
                            Margin="16,0,16,18">

                <CollectionView.ItemTemplate>

                    <DataTemplate x:DataType="models:FoodItem">

                        <!-- 食物卡片 -->
                        <Border StrokeThickness="1"
                                Stroke="#D6C2FF"
                                BackgroundColor="#FFFFFF"
                                Padding="0"
                                Margin="0,0,0,12">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <Border.Shadow>
                                <Shadow Brush="#22000000"
                                        Offset="0,4"
                                        Radius="10"
                                        Opacity="0.15" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="8,*">

                                <!-- 左侧紫色条 -->
                                <BoxView BackgroundColor="#CDB4FF" />

                                <Grid Grid.Column="1"
                                      Padding="16"
                                      RowDefinitions="Auto,Auto,Auto,Auto"
                                      ColumnDefinitions="*,Auto"
                                      RowSpacing="8"
                                      ColumnSpacing="10">

                                    <!-- 食物名称 -->
                                    <Label Text="{Binding Name}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="#3F3152"
                                           SemanticProperties.HeadingLevel="Level2" />

                                    <!-- 卡路里 -->
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="#FFF2C7"
                                            Padding="10,5">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10" />
                                        </Border.StrokeShape>

                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#A06B00" />

                                    </Border>

                                    <!-- 描述 -->
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="14"
                                           TextColor="#6D5D82"
                                           LineBreakMode="TailTruncation" />

                                    <!-- 营养信息 -->
                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="13"
                                           TextColor="#5A8F6B" />

                                    <!-- 底部 -->
                                    <Grid Grid.Row="3"
                                          Grid.ColumnSpan="2"
                                          ColumnDefinitions="*,Auto"
                                          Margin="0,4,0,0">

                                        <!-- 分类 -->
                                        <Label Text="{Binding Category}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#8B6FB3" />

                                        <!-- Details 按钮 -->
                                        <Button Grid.Column="1"
                                                Text="Details"
                                                Padding="14,8"
                                                BackgroundColor="#FFE9A8"
                                                TextColor="#4B3B5A"
                                                CornerRadius="14"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked"
                                                SemanticProperties.Hint="Open nutrition details" />

                                    </Grid>

                                </Grid>

                            </Grid>

                        </Border>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </RefreshView>

    </Grid>

</ContentPage>
