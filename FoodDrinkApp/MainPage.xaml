<?xml version="1.0" encoding="utf-8" ?>

<!-- Main dashboard page displaying food and beverage records -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite">

    <!-- Main page layout -->
    <Grid RowDefinitions="Auto,*">

        <!-- Gradient page background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="0,1">

                <GradientStop Color="{AppThemeBinding Light=#FBF8FF, Dark=#181422}"
                              Offset="0.0" />

                <GradientStop Color="{AppThemeBinding Light=#F3ECFF, Dark=#221B31}"
                              Offset="0.45" />

                <GradientStop Color="{AppThemeBinding Light=#EEE6FF, Dark=#2C2340}"
                              Offset="1.0" />

            </LinearGradientBrush>
        </Grid.Background>

        <!-- Header section -->
        <VerticalStackLayout Padding="20,18,20,10"
                             Spacing="18">

            <!-- Dashboard summary card -->
            <Border Padding="22"
                    StrokeThickness="0">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="30" />
                </Border.StrokeShape>

                <!-- Summary card gradient background -->
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">

                        <GradientStop Color="{AppThemeBinding Light=#DCC7FF, Dark=#46356A}"
                                      Offset="0.0" />

                        <GradientStop Color="{AppThemeBinding Light=#EFE5FF, Dark=#382A57}"
                                      Offset="0.55" />

                        <GradientStop Color="{AppThemeBinding Light=#FFF8D7, Dark=#514020}"
                                      Offset="1.0" />

                    </LinearGradientBrush>
                </Border.Background>

                <!-- Card shadow effect -->
                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,6"
                            Radius="18"
                            Opacity="0.16" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="18">

                    <!-- Dashboard title and introduction -->
                    <VerticalStackLayout Spacing="6">

                        <Label Text="Healthy Meal Dashboard"
                               FontSize="32"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#473659, Dark=#F5EEFF}"
                               SemanticProperties.HeadingLevel="Level1" />

                        <Label Text="Keep track of nutrition intake, favourite meals, and daily eating patterns."
                               FontSize="15"
                               LineHeight="1.3"
                               TextColor="{AppThemeBinding Light=#67587A, Dark=#D6C8F0}" />

                    </VerticalStackLayout>

                    <!-- Dashboard statistics cards -->
                    <Grid ColumnDefinitions="*,*,*"
                          ColumnSpacing="10">

                        <!-- Total entries statistic -->
                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#34274F}"
                                Padding="12"
                                StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="3">

                                <Label Text="Entries"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#8D7AA8, Dark=#D0C2EA}" />

                                <Label Text="4"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}" />

                            </VerticalStackLayout>

                        </Border>

                        <!-- Total calories statistic -->
                        <Border Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light=#FFF5CF, Dark=#55431D}"
                                Padding="12"
                                StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="3">

                                <Label Text="Energy"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#B07B00, Dark=#FFE08A}" />

                                <Label Text="1650"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#8C6200, Dark=#FFF4CC}" />

                            </VerticalStackLayout>

                        </Border>

                        <!-- Total protein statistic -->
                        <Border Grid.Column="2"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#34274F}"
                                Padding="12"
                                StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>

                            <VerticalStackLayout Spacing="3">

                                <Label Text="Protein"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=#8D7AA8, Dark=#D0C2EA}" />

                                <Label Text="88g"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}" />

                            </VerticalStackLayout>

                        </Border>

                    </Grid>

                    <!-- Search and add record section -->
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">

                        <!-- Search bar container -->
                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#34274F}"
                                Stroke="{AppThemeBinding Light=#DDD1FF, Dark=#4E3C74}"
                                StrokeThickness="1"
                                Padding="4,0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="22" />
                            </Border.StrokeShape>

                            <!-- Food search bar -->
                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Find meals, drinks, or ingredients"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       BackgroundColor="Transparent"
                                       TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#F5EEFF}"
                                       PlaceholderColor="{AppThemeBinding Light=#A393BE, Dark=#BFAFDC}"
                                       SemanticProperties.Hint="Search meal records" />

                        </Border>

                        <!-- Add new record button -->
                        <Border Grid.Column="1"
                                BackgroundColor="{AppThemeBinding Light=#FFE7A3, Dark=#E0B84F}"
                                Padding="16,0"
                                StrokeThickness="0">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>

                            <Button Text="+"
                                    FontSize="24"
                                    FontAttributes="Bold"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#5A476D, Dark=#2B1C00}"
                                    Clicked="OnAddClicked"
                                    SemanticProperties.Hint="Add a new meal" />

                        </Border>

                    </Grid>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>

        <!-- Refreshable food list -->
        <RefreshView Grid.Row="1"
                     x:Name="FoodRefreshView"
                     Refreshing="OnRefreshing">

            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            Margin="18,0,18,20"
                            EmptyView="No saved meal records found.">

                <CollectionView.ItemTemplate>

                    <!-- Template for each food item -->
                    <DataTemplate x:DataType="models:FoodItem">

                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2E2444}"
                                Stroke="{AppThemeBinding Light=#DDD0FF, Dark=#49376B}"
                                StrokeThickness="1"
                                Padding="18"
                                Margin="0,0,0,16">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="26" />
                            </Border.StrokeShape>

                            <!-- Item card shadow -->
                            <Border.Shadow>
                                <Shadow Brush="#16000000"
                                        Offset="0,5"
                                        Radius="12"
                                        Opacity="0.12" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="14">

                                <!-- Food name and calorie badge -->
                                <Grid ColumnDefinitions="*,Auto">

                                    <VerticalStackLayout Spacing="3">

                                        <!-- Food name -->
                                        <Label Text="{Binding Name}"
                                               FontSize="24"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#463456, Dark=#F7F2FF}" />

                                        <!-- Food category -->
                                        <Label Text="{Binding Category}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#9578BF, Dark=#CDB7F4}" />

                                    </VerticalStackLayout>

                                    <!-- Calories badge -->
                                    <Border Grid.Column="1"
                                            BackgroundColor="{AppThemeBinding Light=#FFF0BE, Dark=#5C471A}"
                                            Padding="12,6"
                                            VerticalOptions="Start">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>

                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#9A6800, Dark=#FFE49A}" />

                                    </Border>

                                </Grid>

                                <!-- Food description -->
                                <Label Text="{Binding Description}"
                                       FontSize="14"
                                       LineHeight="1.3"
                                       TextColor="{AppThemeBinding Light=#6E5F82, Dark=#D7C9F0}"
                                       LineBreakMode="TailTruncation" />

                                <!-- Nutrition summary cards -->
                                <Grid ColumnDefinitions="*,*,*"
                                      ColumnSpacing="10">

                                    <!-- Protein value -->
                                    <Border BackgroundColor="{AppThemeBinding Light=#F8F4FF, Dark=#392B58}"
                                            Padding="10">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>

                                        <VerticalStackLayout>

                                            <Label Text="Protein"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light=#8D7AA8, Dark=#D1C2EC}" />

                                            <Label Text="{Binding Protein}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}" />

                                        </VerticalStackLayout>

                                    </Border>

                                    <!-- Carbohydrates value -->
                                    <Border Grid.Column="1"
                                            BackgroundColor="{AppThemeBinding Light=#F8F4FF, Dark=#392B58}"
                                            Padding="10">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>

                                        <VerticalStackLayout>

                                            <Label Text="Carbs"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light=#8D7AA8, Dark=#D1C2EC}" />

                                            <Label Text="{Binding Carbs}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}" />

                                        </VerticalStackLayout>

                                    </Border>

                                    <!-- Fat value -->
                                    <Border Grid.Column="2"
                                            BackgroundColor="{AppThemeBinding Light=#F8F4FF, Dark=#392B58}"
                                            Padding="10">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="14" />
                                        </Border.StrokeShape>

                                        <VerticalStackLayout>

                                            <Label Text="Fat"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light=#8D7AA8, Dark=#D1C2EC}" />

                                            <Label Text="{Binding Fat}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}" />

                                        </VerticalStackLayout>

                                    </Border>

                                </Grid>

                                <!-- Open details page button -->
                                <Button Text="View Nutrition Details"
                                        BackgroundColor="{AppThemeBinding Light=#FFE9A8, Dark=#E0B84F}"
                                        TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#2B1C00}"
                                        FontAttributes="Bold"
                                        CornerRadius="18"
                                        HeightRequest="46"
                                        CommandParameter="{Binding Id}"
                                        Clicked="OnDetailsClicked"
                                        SemanticProperties.Hint="Open nutrition details" />

                            </VerticalStackLayout>

                        </Border>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </RefreshView>

    </Grid>

</ContentPage>