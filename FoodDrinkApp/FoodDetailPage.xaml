<?xml version="1.0" encoding="utf-8" ?>

<!-- Food nutrition detail page -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details"
             BackgroundColor="{AppThemeBinding Light=#F6F0FF, Dark=#1F1A26}">

    <ScrollView>

        <!-- Page background gradient -->
        <ScrollView.Background>
            <AppThemeBinding>

                <!-- Light mode background -->
                <AppThemeBinding.Light>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">

                        <GradientStop Color="#F6F0FF"
                                      Offset="0.0" />

                        <GradientStop Color="#F2EAFF"
                                      Offset="0.5" />

                        <GradientStop Color="#EEE4FF"
                                      Offset="1.0" />

                    </LinearGradientBrush>
                </AppThemeBinding.Light>

                <!-- Dark mode background -->
                <AppThemeBinding.Dark>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="0,1">

                        <GradientStop Color="#1F1A26"
                                      Offset="0.0" />

                        <GradientStop Color="#2A2234"
                                      Offset="0.5" />

                        <GradientStop Color="#342B40"
                                      Offset="1.0" />

                    </LinearGradientBrush>
                </AppThemeBinding.Dark>

            </AppThemeBinding>
        </ScrollView.Background>

        <!-- Main page content -->
        <VerticalStackLayout Padding="22"
                             Spacing="16">

            <!-- Header information card -->
            <Border StrokeThickness="0"
                    Padding="22">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <!-- Gradient card background -->
                <Border.Background>
                    <AppThemeBinding>

                        <!-- Light mode card -->
                        <AppThemeBinding.Light>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">

                                <GradientStop Color="#D7C1FF"
                                              Offset="0.0" />

                                <GradientStop Color="#E8DAFF"
                                              Offset="0.55" />

                                <GradientStop Color="#FFE9A8"
                                              Offset="1.0" />

                            </LinearGradientBrush>
                        </AppThemeBinding.Light>

                        <!-- Dark mode card -->
                        <AppThemeBinding.Dark>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,1">

                                <GradientStop Color="#5A4382"
                                              Offset="0.0" />

                                <GradientStop Color="#46355F"
                                              Offset="0.55" />

                                <GradientStop Color="#6E5A2A"
                                              Offset="1.0" />

                            </LinearGradientBrush>
                        </AppThemeBinding.Dark>

                    </AppThemeBinding>
                </Border.Background>

                <!-- Card shadow effect -->
                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,5"
                            Radius="12"
                            Opacity="0.18" />
                </Border.Shadow>

                <!-- Food summary information -->
                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="8">

                    <!-- Food name -->
                    <Label x:Name="NameLabel"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                           SemanticProperties.HeadingLevel="Level1" />

                    <!-- Food category -->
                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6F5C84, Dark=#DDD2F0}" />

                    <!-- Calories display -->
                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#A06B00, Dark=#FFD978}" />

                </Grid>

            </Border>

            <!-- Nutrition information card -->
            <Border Stroke="{AppThemeBinding Light=#D6C2FF, Dark=#514160}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2E2638}"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>

                <!-- Card shadow -->
                <Border.Shadow>
                    <Shadow Brush="#16000000"
                            Offset="0,3"
                            Radius="8"
                            Opacity="0.12" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">

                    <!-- Section title -->
                    <Label Text="Meal Nutrition Summary"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#7A5AA6, Dark=#D9C7FF}" />

                    <!-- Macronutrient information -->
                    <Label x:Name="MacroLabel"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#5A8F6B, Dark=#A7E2B6}" />

                    <!-- Divider line -->
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light=#E5D7FF, Dark=#514160}" />

                    <!-- Food description -->
                    <Label x:Name="DescriptionLabel"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#6D5D82, Dark=#DDD2F0}" />

                    <!-- Allergy information -->
                    <Label x:Name="AllergyLabel"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#B57B00, Dark=#FFD978}" />

                </VerticalStackLayout>

            </Border>

            <!-- Action buttons section -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">

                <!-- Text-to-Speech button -->
                <Button Text="Play Summary"
                        BackgroundColor="{AppThemeBinding Light=#CDB4FF, Dark=#7757B2}"
                        TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />

                <!-- Stop speech button -->
                <Button Grid.Column="1"
                        Text="Stop Audio"
                        BackgroundColor="{AppThemeBinding Light=#FFF7D6, Dark=#4A3B20}"
                        BorderColor="{AppThemeBinding Light=#E6D2A5, Dark=#7A6333}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=#7B5A00, Dark=#FFD978}"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />

            </Grid>

            <!-- Device vibration reminder button -->
            <Button Text="Meal Reminder Vibration"
                    BackgroundColor="{AppThemeBinding Light=#FFE9A8, Dark=#6A5523}"
                    TextColor="{AppThemeBinding Light=#4B3B5A, Dark=#FFFFFF}"
                    CornerRadius="18"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    Clicked="OnVibrateClicked"
                    SemanticProperties.Hint="Use mobile vibration as a meal reminder" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>