<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details">

    <ScrollView>

        <!-- 页面背景 -->
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F6F0FF" Offset="0.0" />
                <GradientStop Color="#F2EAFF" Offset="0.5" />
                <GradientStop Color="#EEE4FF" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="22"
                             Spacing="16">

            <!-- 顶部渐变卡片 -->
            <Border StrokeThickness="0"
                    Padding="22">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">

                        <GradientStop Color="#CDB4FF"
                                      Offset="0.0" />

                        <GradientStop Color="#DCC6FF"
                                      Offset="0.5" />

                        <GradientStop Color="#FFE9A8"
                                      Offset="1.0" />

                    </LinearGradientBrush>
                </Border.Background>

                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,5"
                            Radius="12"
                            Opacity="0.18" />
                </Border.Shadow>

                <Grid RowDefinitions="Auto,Auto,Auto"
                      RowSpacing="8">

                    <Label x:Name="NameLabel"
                           FontSize="30"
                           FontAttributes="Bold"
                           TextColor="#4B3B5A"
                           SemanticProperties.HeadingLevel="Level1" />

                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="15"
                           TextColor="#6F5C84" />

                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="#A06B00" />

                </Grid>

            </Border>

            <!-- Nutrition 卡片 -->
            <Border StrokeThickness="1"
                    Stroke="#D6C2FF"
                    BackgroundColor="#FFFFFF"
                    Padding="18">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="#16000000"
                            Offset="0,3"
                            Radius="8"
                            Opacity="0.12" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">

                    <Label Text="Nutrition overview"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="#7A5AA6" />

                    <Label x:Name="MacroLabel"
                           FontSize="16"
                           TextColor="#5A8F6B" />

                    <BoxView HeightRequest="1"
                             Color="#E5D7FF" />

                    <Label x:Name="DescriptionLabel"
                           FontSize="15"
                           TextColor="#6D5D82" />

                    <Label x:Name="AllergyLabel"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#B57B00" />

                </VerticalStackLayout>

            </Border>

            <!-- 按钮区域 -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">

                <!-- Read -->
                <Button Text="Read summary"
                        BackgroundColor="#CDB4FF"
                        TextColor="#4B3B5A"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />

                <!-- Stop -->
                <Button Grid.Column="1"
                        Text="Stop reading"
                        BackgroundColor="#FFF7D6"
                        BorderColor="#E6D2A5"
                        BorderWidth="1"
                        TextColor="#7B5A00"
                        CornerRadius="16"
                        FontAttributes="Bold"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />

            </Grid>

            <!-- 震动按钮 -->
            <Button Text="Vibration reminder"
                    BackgroundColor="#FFE9A8"
                    TextColor="#4B3B5A"
                    CornerRadius="18"
                    FontAttributes="Bold"
                    HeightRequest="56"
                    Clicked="OnVibrateClicked"
                    SemanticProperties.Hint="Use mobile vibration as a meal reminder" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>